# Credentials & secrets
.env
reference/CREDENTIALS.md
*.key
*.pem

# IDE & OS
.vscode/
.idea/

# Claude Code — track agents and shared settings, ignore machine-specific files
.claude/*
!.claude/agents/
!.claude/settings.json
.mcp.json
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Build & dependencies
node_modules/
dist/
build/
*.egg-info/
__pycache__/
.Python

# Temp & cache
tmp/
*.tmp
*.cache
.pytest_cache/

# Weewx dev artifacts
weewx-output/
Belchertown-dev/
*.backup.*

# Nextcloud-synced local files (credentials, machine-specific config)
.local/

# Child repos (independent git repos per ADR-036) — meta tracks the directory marker only
repos/*
!repos/.gitkeep
